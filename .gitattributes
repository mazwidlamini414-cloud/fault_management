# Auto-detect text files and enforce LF line endings on checkout
* text=auto eol=lf

# Force LF for all text-based project files
*.php text eol=lf
*.sh text eol=lf
*.sql text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.htaccess text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf
*.env text eol=lf

# Binary files - never touch line endings
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.zip binary
*.pdf binary
